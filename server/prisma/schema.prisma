generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  bot
}

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @default(now())
  content    String   @db.Text
  role       Role
}
